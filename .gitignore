data/wallpapers/*.jpg
data/wallpapers/*.jpeg
data/wallpapers/*.png
!data/wallpapers/.gitkeep

# Logs
*.log
download.log

# Compressed archives (keep manifests but not the archives themselves)
*.zip
*.tar.gz
!data/wallpapers.zip
